# Copy to ~/.zsh_secrets and fill in. Never commit the real file.
#
#   cp ~/dotfiles/zsh/.zsh_secrets.example ~/.zsh_secrets
#   chmod 600 ~/.zsh_secrets
#
# Used by OpenCode ({env:VAR} in ~/.config/opencode/opencode.json),
# pi (cursor provider + exa-search/obsidian skills), and Cursor MCP templates.

# export CURSOR_API_KEY=''          # pi-cursor-sdk / Cursor provider auth
# export EXA_API_KEY=''             # pi exa-search skill
# export OBSIDIAN_MCP_TOKEN=''      # obsidian CLI / Local REST API plugin

# Add other machine-local secrets here (API keys, private URLs, etc.).
