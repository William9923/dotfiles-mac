# Files / dirs that should never be symlinked into $HOME by stow.
# Bare patterns match basenames anywhere in a package. Anchored patterns
# match paths rooted at the package boundary.

\.git
\.gitignore
\.gitattributes
\.stow-local-ignore
\.DS_Store
node_modules
\.env
\.env\..*
.*\.log
.*\.tmp
.*\.bak
.*\.bak\..*

# Root-level repository files are not packages.
^/README\.md$
^/LICENSE$
^/Makefile$
^/docs$
^/~$
^/\.nvimlog$
^/setup\.sh$
^/test-bootstrap\.sh$
^/scripts$
^/macos$

# Cursor reads from ~/Library/Application Support/Cursor/User/ on macOS.
# The repo tracks it under config/.config/Cursor and setup.sh links it manually.
^/\.config/Cursor$
