// Place your key bindings in this file to override the defaults
[
  // Add VSCode-layer keybindings here when a binding can't live inside vim.* settings
  // (e.g. when focus is in a non-text view like the file explorer).

  // --- Agents ---
  // Open the Agents Window (multi-agent / cloud agents view)
  {
    "key": "cmd+shift+a",
    "command": "workbench.action.openAgentsView"
  },
  // New agent chat tab
  {
    "key": "cmd+shift+n",
    "command": "composer.newAgentChat"
  },
  // Show background agent history
  {
    "key": "cmd+shift+h",
    "command": "workbench.action.backgroundComposer.showBackgroundAgentHistory"
  }
]
